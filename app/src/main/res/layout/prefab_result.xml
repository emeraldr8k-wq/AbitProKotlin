<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    tools:showIn="@layout/activity_result"

    android:layout_height="160dp"
    app:layout_constraintTop_toTopOf="parent"
    tools:layout_editor_absoluteX="0dp"
    android:padding="10dp"
    android:layout_marginEnd="11dp"
    android:layout_marginStart="11dp"
    android:layout_marginTop="5dp"
    android:background="@drawable/prefab_result_style">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/imageView"
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:srcCompat="@drawable/ic_launcher_background" />

        <LinearLayout
            android:id="@+id/vuz_name_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/vuz_name"
                android:layout_width="match_parent"
                android:layout_height="53dp"
                android:text="Санкт-Петербургский государственный экономический университет"
                android:textColor="@color/DWhite1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"

                    android:gravity="center_horizontal"

                    android:text="Бюджет"
                    android:textColor="@color/DWhite1"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:text="Платное"
                    android:textColor="@color/DWhite1"
                    android:textSize="12dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="5dp">


            <TableLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:stretchColumns="2">

                <TableRow>

                    <TextView
                        android:layout_width="50dp"
                        android:layout_gravity="start"
                        android:paddingHorizontal="8dp"
                        android:text="@string/value"
                        android:textColor="@color/DWhite1"
                        android:textSize="12dp" />

                    <TextView
                        android:id="@+id/budg_ball"
                        android:layout_width="50dp"
                        android:layout_gravity="end"
                        android:paddingHorizontal="8dp"
                        android:text="350"
                        android:textColor="@color/DWhite1"
                        android:textSize="12dp" />
                </TableRow>

            </TableLayout>

            <TableLayout
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:stretchColumns="2">

                <TableRow
                    android:layout_marginStart="10dp">


                    <TextView
                        android:layout_gravity="start"
                        android:paddingHorizontal="8dp"
                        android:text="@string/value"
                        android:textColor="@color/DWhite1"
                        android:textSize="12dp" />

                    <TextView
                        android:id="@+id/paid_ball"
                        android:layout_width="50dp"
                        android:layout_gravity="end"
                        android:paddingHorizontal="8dp"
                        android:text="200"
                        android:textColor="@color/DWhite1"
                        android:textSize="12dp" />
                </TableRow>

            </TableLayout>

        </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">


                <TableLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:stretchColumns="2">

                    <TableRow>

                        <TextView
                            android:layout_width="50dp"
                            android:layout_gravity="start"
                            android:paddingHorizontal="8dp"
                            android:text="@string/places"
                            android:textColor="@color/DWhite1"
                            android:textSize="12dp" />

                        <TextView
                            android:id="@+id/budg_place"
                            android:layout_width="50dp"
                            android:layout_gravity="end"
                            android:paddingHorizontal="8dp"
                            android:text="914"
                            android:textColor="@color/DWhite1"
                            android:textSize="12dp" />
                    </TableRow>

                </TableLayout>

                <TableLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:stretchColumns="2">

                    <TableRow
                        android:layout_marginStart="10dp">


                        <TextView
                            android:layout_gravity="start"
                            android:paddingHorizontal="8dp"
                            android:text="@string/places"
                            android:textColor="@color/DWhite1"
                            android:textSize="12dp" />

                        <TextView
                            android:id="@+id/paid_place"
                            android:layout_width="50dp"
                            android:layout_gravity="end"
                            android:paddingHorizontal="8dp"
                            android:text="1024"
                            android:textColor="@color/DWhite1"
                            android:textSize="12dp" />
                    </TableRow>

                </TableLayout>
            </LinearLayout>

            <TableLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:stretchColumns="2"
                android:layout_marginStart="87dp">

                <TableRow>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_gravity="start"
                        android:paddingHorizontal="8dp"
                        android:text="стоимость:"
                        android:textColor="@color/DWhite1"
                        android:textSize="12dp" />

                    <TextView
                        android:id="@+id/cost_value"
                        android:layout_width="wrap_content"
                        android:layout_gravity="start"
                        android:gravity="start"

                        android:paddingHorizontal="8dp"
                        android:text="15 000"
                        android:textColor="@color/DWhite1"
                        android:textSize="12dp" />
                </TableRow>
            </TableLayout>



        </LinearLayout>
    </LinearLayout>

</FrameLayout>