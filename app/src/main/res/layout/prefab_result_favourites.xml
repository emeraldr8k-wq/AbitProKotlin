<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"


    android:layout_height="160dp"
    android:layout_width="match_parent"
    app:layout_constraintTop_toTopOf="parent"
    tools:layout_editor_absoluteX="0dp"
    android:padding="10dp"
    android:layout_marginEnd="11dp"
    android:layout_marginStart="11dp"
    android:layout_marginTop="5dp"
    android:background="@drawable/prefab_result_style">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/imageView"
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:srcCompat="@drawable/ic_launcher_background" />

        <LinearLayout
            android:id="@+id/vuz_name_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="horizontal">
            <TextView
                android:id="@+id/vuz_name"
                android:layout_width="0dp"
                android:layout_height="53dp"
                android:layout_weight="1"
                android:textSize="14sp"
                android:text="Санкт-Петербургский государственный экономический университет"
                android:textColor="@color/DWhite1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bottomButton_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bottom_bar_button_background"
                    android:padding="0dp"
                    app:backgroundTint="@null"
                    app:icon="@drawable/image_cancel"
                    app:iconGravity="textStart"
                    app:iconTint="@color/DWhite1"/>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"

                    android:gravity="center_horizontal"

                    android:text="Бюджет"
                    android:textColor="@color/DWhite1"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:text="Платное"
                    android:textColor="@color/DWhite1"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/value"
                            android:textColor="@color/DWhite1"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/budg_ball"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="200"
                            android:textColor="@color/DWhite1"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/places"
                            android:textColor="@color/DWhite1"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/budg_place"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="200"
                            android:textColor="@color/DWhite1"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="5dp"
                    android:layout_marginStart="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/value"
                            android:textColor="@color/DWhite1"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/paid_ball"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="200"
                            android:textColor="@color/DWhite1"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/places"
                            android:textColor="@color/DWhite1"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/paid_places"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="200"
                            android:textColor="@color/DWhite1"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal">
                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:paddingHorizontal="8dp"
                        android:text="Стоимость:"
                        android:textColor="@color/DWhite1"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/cost_value"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:gravity="start"
                        android:text="15 000"
                        android:textColor="@color/DWhite1"
                        android:textSize="12sp" />
            </LinearLayout>



        </LinearLayout>
    </LinearLayout>

</FrameLayout>